#!/bin/bash

# --- CONFIGURATION ---
WAN_IFACE="ovs_eth0"        # Interface connected to your router/internet
DMZ_IFACE="ovs_eth1"        # Interface connected to your server
DMZ_IP="192.168.10.50"      # Server IP address
LAN_NET="192.168.1.0/24"    # Your home network
DMZ_NET="192.168.10.0/24"   # Your server network

# --- INITIALIZATION ---
sysctl -w net.ipv4.ip_forward=1
sysctl -w net.ipv4.conf.${WAN_IFACE}.rp_filter=1
sysctl -w net.ipv4.conf.${DMZ_IFACE}.rp_filter=1

# --- CLEANUP ---
iptables -F DEFAULT_FORWARD 2>/dev/null
iptables -t nat -F PREROUTING
iptables -t nat -F POSTROUTING

# --- SECURITY & NAT ---
# Masquerade outbound traffic so the server can access the internet
iptables -t nat -A POSTROUTING -s ${DMZ_NET} -o ${WAN_IFACE} -j MASQUERADE

# Allow established connections
iptables -A DEFAULT_FORWARD -m state --state RELATED,ESTABLISHED -j ACCEPT

# Allow SSH access to the server
iptables -A DEFAULT_FORWARD -i ${WAN_IFACE} -o ${DMZ_IFACE} -p tcp -s ${LAN_NET} -d ${DMZ_IP} --dport 22 -j ACCEPT

# NAT (Port Forwarding)
# Example: Access server port 9000 via NAS port 9000
iptables -t nat -A PREROUTING -i ${WAN_IFACE} -p tcp --dport 9000 -j DNAT --to-destination ${DMZ_IP}:9000

# --- ISOLATION ---
# Block direct access from the server to the home network
iptables -A DEFAULT_FORWARD -i ${DMZ_IFACE} -o ${WAN_IFACE} -d ${LAN_NET} -j DROP
